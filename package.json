{
  "name": "laozi-cli",
  "version": "0.1.0",
  "description": "A lightweight CLI to help families identify misinformation targeting elderly internet users.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "laozi": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "keywords": [
    "cli",
    "misinformation",
    "elderly",
    "ai",
    "fact-check"
  ],
  "author": "LAOZI.ART",
  "license": "MIT",
  "files": [
    "dist",
    "prompts",
    "install.sh",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.52.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.5"
  }
}
